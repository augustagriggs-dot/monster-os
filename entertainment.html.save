        .block { background: #222; border: 1px solid #444; padding: 20px; border-radius: 8px; color: #ddd; text-decoration: none; font-weight: bold; transition: 0.3s; display: flex; align-items: center; justify-content: center; height: 60px; text-align: center; }
        .block:hover { background: gold; color: #000; transform: scale(1.05); border-color: #fff; box-shadow: 0 0 15px gold; }
        .movies { border-left: 5px solid #e50914; }
        .kids { border-left: 5px solid #ff69b4; }
        .sports { border-left: 5px solid #32cd32; }
