o#!/bin/bash
# GOSTREAMER Monster OS - Master UI Builder
# This script generates the high-end HTML build automatically.

TARGET="/home/theland/monster_system/active_index.html"

echo "🟢 Generating GOSTREAMER Monster OS Elite UI..."

cat <<EOF > "$TARGET"
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>GOSTREAMER Monster OS</title>
    <style>
        body {
            background: url('img/bg.jpeg') no-repeat center center fixed;
            background-size: cover;
            background-color: #050505;
            color: #ffffff;
            font-family: 'Segoe UI', sans-serif;
            margin: 0; padding: 40px;
        }

        /* HEADER & SEARCH */
        .header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 50px; padding: 20px;
            background: rgba(0, 0, 0, 0.6);
            border-radius: 15px; backdrop-filter: blur(10px);
            border: 1px solid rgba(57, 255, 20, 0.3);
        }

        .brand { display: flex; align-items: center; }
        .brand img { height: 60px; filter: drop-shadow(0 0 10px #39FF14); margin-right: 15px; }
        .brand h1 { font-size: 32px; margin: 0; color: #39FF14; letter-spacing: 2px; }

        .search-box { flex-grow: 1; max-width: 500px; margin: 0 30px; }
        .search-box form { display: flex; background: rgba(255,255,255,0.1); border-radius: 50px; border: 1px solid #39FF14; padding: 5px; }
        .search-box input { background: transparent; border: none; color: white; padding: 10px 20px; width: 100%; outline: none; font-size: 16px; }
        .search-box button { background: #39FF14; border: none; padding: 10px 20px; border-radius: 40px; font-weight: bold; cursor: pointer; }

        /* ROWS & BLOCKS */
        .row-title { color: #39FF14; font-size: 24px; margin: 30px 0 15px 0; text-transform: uppercase; font-weight: bold; border-left: 4px solid #39FF14; padding-left: 15px; }
        .container { display: grid; grid-template-columns: repeat(4, 1fr); gap: 25px; }
        
        .block { 
            text-decoration: none; color: white; transition: 0.4s; 
            background: rgba(255,255,255,0.05); border-radius: 12px; overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
        }
        .block img { width: 100%; height: 180px; object-fit: cover; }
        .block span { display: block; text-align: center; padding: 15px; font-weight: bold; font-size: 18px; }

        .block:hover { transform: scale(1.05); border-color: #39FF14; box-shadow: 0 0 20px rgba(57, 255, 20, 0.5); }
        .block:hover span { color: #39FF14; }
    </style>
</head>
<body>

    <div class="header">
        <div class="brand">
            <img src="img/logo.png">
            <h1>GOSTREAMER</h1>
        </div>

        <div class="search-box">
            <form action="https://duckduckgo.com/" method="get">
                <input type="text" name="q" placeholder="Search the web..." autocomplete="off">
                <button type="submit">GO</button>
            </form>
        </div>

        <div id="clock" style="font-size: 24px; color: #39FF14; font-weight: bold;"></div>
    </div>

    <div class="row-title">🎬 Premium Movies</div>
    <div class="container">
        <a href="https://cineby.gd" class="block"><img src="img/movieposter1.jpeg"><span>CINEBY</span></a>
        <a href="https://hdtoday.tv" class="block"><img src="img/movieposter2.jpeg"><span>HD TODAY</span></a>
        <a href="https://bflix.to" class="block"><img src="img/movieposter3.jpeg"><span>BFLIX</span></a>
        <a href="https://vidsrc.to" class="block"><img src="img/movieposter4.jpeg"><span>VIDSRC</span></a>
    </div>

    <div class="row-title">🏈 Live Sports</div>
    <div class="container">
        <a href="https://thestreameast.to" class="block"><img src="img/sports1.jpeg"><span>STREAMEAST</span></a>
        <a href="https://methstreams.com" class="block"><img src="img/sports2.jpeg"><span>METH STREAMS</span></a>
        <a href="https://vipleague.im" class="block"><img src="img/sports3.jpeg"><span>VIP LEAGUE</span></a>
        <a href="https://sportshub.fan" class="block"><img src="img/sportsposter4.jpeg"><span>SPORTS HUB</span></a>
    </div>

    <script>
        function updateClock() {
            const now = new Date();
            document.getElementById('clock').innerText = now.toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'});
        }
        setInterval(updateClock, 1000); updateClock();
    </script>
</body>
</html>
EOF

echo "✅ Monster OS Build Updated Successfully!"
